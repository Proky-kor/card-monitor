# card-monitor 설정 예시. 이 파일을 .env 로 복사해 값을 채우세요. (.env는 git/배포 제외)

# 수집 대상 회사 (쉼표구분, 비우면 등록된 전체). 예: lotte
CARD_COMPANIES=

# 수집 동작
CARD_HTTP_TIMEOUT=25
CARD_REQUEST_DELAY=0.5
CARD_NEW_DAYS=30
# 신규등록(모니터링) 배지 기준: first_seen 이후 N일
CARD_NEW_REGISTERED_DAYS=14

# Teams 알림 웹훅 URL (Incoming Webhook 또는 Power Automate). 비우면 알림 끔.
# ※ 비밀값 — 채팅/메일 공유 금지, 이 파일에 직접 입력. 자동화_안내.md 참고.
CARD_TEAMS_WEBHOOK_URL=

# 서버 (중앙 호스트에서만 구동)
CARD_SERVE_HOST=0.0.0.0
CARD_SERVE_PORT=8001

# 저장 위치 (기본값이면 비워둬도 됨)
# CARD_DB_PATH=
# CARD_IMAGE_DIR=
